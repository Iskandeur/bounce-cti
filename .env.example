# --- Core sources (existing) ---
VIRUSTOTAL_API_KEY=
URLSCAN_API_KEY=
ONYPHE_API_KEY=
SHODAN_API_KEY=
OTX_API_KEY=
# abuse.ch (URLhaus + MalwareBazaar) — free, register at https://auth.abuse.ch/
ABUSECH_AUTH_KEY=

# --- New CTI sources (Phase 3) ---
# AbuseIPDB — IP reputation. Free 1000 req/day. https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=
# CertSpotter (SSLMate) — continuous CT cert tracking. Free 100 req/day. https://sslmate.com/account/api_credentials
CERTSPOTTER_API_KEY=
# Netlas — scanner DB (host search, JARM, favicon). Free 50 req/day. https://app.netlas.io/registration/
NETLAS_API_KEY=
# Whoxy — reverse WHOIS (registrant email/name → domains). 1500 req lifetime free. https://www.whoxy.com/
WHOXY_API_KEY=
# ZoomEye — scanner DB. Free 10k/month. https://www.zoomeye.org/profile
ZOOMEYE_API_KEY=
# CriminalIP — scanner DB. Free ~50/day. https://www.criminalip.io/register
CRIMINALIP_API_KEY=
# OpenCTI — community knowledge graph (read-only). Demo at https://demo.opencti.io
# exposes a generous 10k/window quota. Set OPENCTI_URL if you point at a private
# instance. The token format is `flgrn_octi_tkn_…` (used as a Bearer header).
OPENCTI_URL=https://demo.opencti.io
OPENCTI_API_KEY=

# --- Tier 1 / Tier 2 sources (added 2026-05-21) ---
# DNSDumpster — passive subdomain enumeration. Free 50 req/day. https://dnsdumpster.com/developer/
DNSDUMPSTER_API_KEY=
# HackerTarget — reverse-IP, host search, geoip. Free anonymous, key recommended (lifts daily cap). https://hackertarget.com/
HACKERTARGET_API_KEY=
# LeakIX — exposed services + data leaks. Free with optional key. https://leakix.net/
LEAKIX_API_KEY=
# Pulsedive — risk-scored IOC enrichment. Free 500 req/month. https://pulsedive.com/api/
PULSEDIVE_API_KEY=
# Censys — host + cert search. Free community 250/month. Accepts either `id:secret` or a personal-access token `censys_<id>_<secret>`. https://search.censys.io/account/api
CENSYS_API_KEY=
# EmailRep.io — email reputation. Free 10/day anonymous, 250/month with key. https://emailrep.io/key
EMAILREP_API_KEY=
# Project Honey Pot http:BL — IPv4 DNSBL reputation. Free, register at https://www.projecthoneypot.org/httpbl_configure.php
PROJECTHONEYPOT_API_KEY=

# --- OSINT / crypto sources ---
# Etherscan — ETH wallet enrichment (balance, transactions, counterparties).
# Free tier with key (5 req/s). https://etherscan.io/myapikey
# BTC enrichment uses blockstream.info (no key); without this key, ETH wallets
# degrade to chain-only. Used by backend/sources/wallet_enrich.py.
ETHERSCAN_API_KEY=

# --- No-auth sources (no env vars needed) ---
# CIRCL Luxembourg hashlookup + vulnerability-lookup (https://hashlookup.circl.lu, https://vulnerability.circl.lu)
# AlienVault IP reputation feed (http://reputation.alienvault.com/reputation.data)
# PhishTank URL check (http://checkurl.phishtank.com/checkurl/)
# Tor exit-relay list (https://check.torproject.org/exit-addresses)
# DNSTwist — local binary, install with `pip install dnstwist`
# blockstream.info — BTC wallet enrichment (Esplora API, no key)

# --- Multi-key rotation (optional) ---
# If set, takes precedence over the single-key form above.
# Format: comma-separated. Useful for rate-limited free tiers.
# Example: VIRUSTOTAL_API_KEYS=key1,key2,key3
# VIRUSTOTAL_API_KEYS=
# NETLAS_API_KEYS=
# CERTSPOTTER_API_KEYS=
# CRIMINALIP_API_KEYS=
# WHOXY_API_KEYS=
# OPENCTI_API_KEYS=
# ETHERSCAN_API_KEYS=

# --- Misc ---
# Path to claude CLI. Defaults to "claude" resolved on PATH; if not on PATH the
# backend also probes ~/.local/bin (the native-installer location), ~/.npm-global/bin,
# /usr/local/bin and /usr/bin. Under systemd the service PATH often omits
# ~/.local/bin, so set this to the absolute path if spawns fail with
# "claude CLI not found" (e.g. CLAUDE_BIN=/home/<user>/.local/bin/claude).
CLAUDE_BIN=claude
# Admin bootstrap PIN (6 digits). If set, the matching user is promoted to admin on startup.
ADMIN_PIN=

# --- Autonomous pivot drain (Phase 4) ---
# After the report is written, the agent runs up to N rounds of an autonomous
# pivot-drain loop that reads its own report.pivot_suggestions + the queue and
# executes them. Set ROUNDS=0 to disable entirely. Each round runs the agent
# for up to MAX_TURNS tool calls and stops early when a round adds fewer than
# CONVERGENCE new nodes (signal that the cluster is exhausted).
# BOUNCE_PIVOT_DRAIN_ROUNDS=3
# BOUNCE_PIVOT_DRAIN_MAX_TURNS=60
# BOUNCE_PIVOT_DRAIN_CONVERGENCE=3
# Global ceiling on cumulative mcp__cti__* calls across all phases. The drain
# loop counts raw CTI calls before each round and stops/clamps so total spend
# stays inside the fast-triage budget (~60-90 calls) instead of overshooting on
# complex multi-tier hubs. Set very high to effectively disable. Default 82.
# BOUNCE_TOTAL_CTI_BUDGET=82
# Global pending-pivot-queue ceiling. Once the pending backlog hits this, new
# auto-enqueued pivots are parked as 'deferred' (skip_reason='queue_ceiling')
# so drain budget is spent on queued work instead of an exploding backlog;
# requeue_missing() promotes deferred→pending. Default 300.
# BOUNCE_PIVOT_QUEUE_MAX=300

# When a Claude-subscription quota error is detected but no reset epoch can be
# recovered from the CLI output, block fresh spawns for this many seconds so
# the graceful-stop gate still engages (and the Resume affordance unlocks
# afterward). Default 3600 (1h). A real resetsAt from the CLI takes precedence.
# BOUNCE_QUOTA_FALLBACK_COOLDOWN_S=3600

# No-first-event watchdog: if a spawned `claude -p` emits no stream-json event
# within this many seconds it is killed and the phase fails fast with an
# `agent_no_output` event (instead of hanging to the 20-min ceiling). Catches a
# wedged spawn — bad binary, broken MCP launch. Default 120. Set 0 to disable.
# BOUNCE_AGENT_FIRST_EVENT_TIMEOUT_S=120
