{
  "mcpServers": {
    "graph": {
      "command": "${BOUNCE_PYTHON}",
      "args": ["-m", "backend.mcp_servers.graph_mcp"],
      "env": {"BOUNCE_INV_ID": "${BOUNCE_INV_ID}", "PYTHONPATH": "${PYTHONPATH}"}
    },
    "cti": {
      "command": "${BOUNCE_PYTHON}",
